# --- Discord Configuration ---
DISCORD_TOKEN=your_discord_bot_token_here
CHANNEL_ID=your_channel_id_here

# --- LLM Intelligence ---
# Providers: "gemini" or "groq"
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Model Override (Optional)
# Gemini default: gemini-2.0-flash | Groq default: llama-3.3-70b-versatile
LLM_MODEL=

# --- Render Deployment & Keep-Alive ---
# Public URL of your bot (e.g., https://totia.onrender.com)
RENDER_URL=
# Health check port (Render automatically sets this via $PORT)
PORT=8080
